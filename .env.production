## WeForYou Frontend - Production Environment
## Public variables only (safe for client bundle)

# Backend base URL (without /api/v1)
NEXT_PUBLIC_API_BASE_URL=https://wfubackend.trickwave.com

# Backend versioned API URL
NEXT_PUBLIC_API_URL=https://wfubackend.trickwave.com/api/v1

# Frontend app URL (update to real production domain if different)
NEXT_PUBLIC_APP_URL=https://wfubackend.trickwave.com

# App branding
NEXT_PUBLIC_APP_NAME=We4You
